# ==============================================================================
# Root Environment Configuration Template
# Copy this file to '.env' at the project root or configure these variables
# individually in the backend and frontend folders.
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Configuration (crm/backend)
# ------------------------------------------------------------------------------
ENVIRONMENT=development
DATABASE_URL=sqlite:///./support_crm.db
CORS_ORIGINS=http://localhost:5173
SECRET_KEY=replace-with-a-long-random-secret-key-for-jwt-signing

# Gemini AI API Key (Optional: Falls back to rule-based defaults if not configured)
GEMINI_API_KEY=your-gemini-api-key-here

# ------------------------------------------------------------------------------
# Frontend Configuration (crm/frontend)
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
